  PRODUCT OPEN GRAPH TAGS TEMPLATE:
  <meta property="og:title" content="{{Product Name}} — Sports Mart Premium Kottarakkara" />
  <meta property="og:description" content="{{Product Description}}" />
  <meta property="og:type" content="product" />
  <meta property="og:url" content="https://sportsmartpremium.in/products/{{PRODUCT_SLUG}}" />
  <meta property="og:image" content="https://sportsmartpremium.in/images/products/{{PRODUCT_SLUG}}-og.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Sports Mart Premium" />
  <meta property="product:price:amount" content="{{PRICE}}" />
  <meta property="product:price:currency" content="INR" />

  TWITTER CARD TAGS TEMPLATE:
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{Product Name}} — Sports Mart Premium" />
  <meta name="twitter:description" content="{{Product Description}}" />
  <meta name="twitter:image" content="https://sportsmartpremium.in/images/products/{{PRODUCT_SLUG}}-og.jpg" />
